{
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node"]
  },
  "include": ["vite.config.ts", "api/**/*.ts", "src/server/**/*.ts"]
}
